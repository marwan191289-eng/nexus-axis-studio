# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Zoho SMTP (for sending)
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_SMTP_USER=info@nexusaxisconsultants.com
ZOHO_SMTP_PASS=YOUR_ZOHO_SMTP_APP_PASSWORD

# Zoho OAuth (optional, for API access)
ZOHO_CLIENT_ID=YOUR_ZOHO_CLIENT_ID
ZOHO_CLIENT_SECRET=YOUR_ZOHO_CLIENT_SECRET
ZOHO_REFRESH_TOKEN=YOUR_ZOHO_REFRESH_TOKEN

# IMAP fallback (worker)
IMAP_HOST=imap.nexusaxisconsultants.com
IMAP_PORT=993
IMAP_USER=info@nexusaxisconsultants.com
IMAP_PASS=YOUR_IMAP_PASSWORD

# App
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
BACKEND_URL=http://localhost:4000   # used for local testing; in v0 this is internal
